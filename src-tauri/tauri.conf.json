{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notes Neurosis",
  "version": "0.1.7",
  "identifier": "com.prettysailorsoldier.notes-neurosis",
  "build": {
    "beforeDevCommand": "node ./node_modules/vite/bin/vite.js",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Notes Neurosis",
        "width": 1100,
        "height": 860,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE2MTM3QzI3RUYwNUZCRDYKUldUVyt3WHZKM3dUcHUzMmlkUGJUVlBTbml5RFc3RUlrS3htR1pvWXFTNTlWREtsaHpqRElaR24K",
      "endpoints": [
        "https://github.com/PrettySailorSoldier/notesNeurosis/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
